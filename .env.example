# veredas de papel — configurações de ambiente
# Copie este arquivo para .env e ajuste os valores.
# Todas as variáveis usam o prefixo VEREDAS_.

# ---------------------------------------------------------------------------
# Geral
# ---------------------------------------------------------------------------
# VEREDAS_DEBUG=false
# VEREDAS_DATA_DIR=~/.veredas          # diretório de dados (banco + cache)

# ---------------------------------------------------------------------------
# Banco de dados (SQLite por padrão — sem configuração necessária)
# ---------------------------------------------------------------------------
# VEREDAS_DB_PATH=~/.veredas/veredas.db
# VEREDAS_DB_ECHO=false                # exibe queries SQL no console

# ---------------------------------------------------------------------------
# Servidor web
# ---------------------------------------------------------------------------
# VEREDAS_WEB_HOST=127.0.0.1
# VEREDAS_WEB_PORT=8000

# ---------------------------------------------------------------------------
# Coletores
# ---------------------------------------------------------------------------
# VEREDAS_COLLECTOR_REQUEST_DELAY=1.0  # segundos entre requisições à API
# VEREDAS_COLLECTOR_MAX_RETRIES=3
# VEREDAS_COLLECTOR_TIMEOUT=30

# ---------------------------------------------------------------------------
# Alertas — Telegram
# Guia de configuração: USER_GUIDE.md → seção 7.1
# ---------------------------------------------------------------------------
# VEREDAS_TELEGRAM_BOT_TOKEN=seu_token_aqui
# VEREDAS_TELEGRAM_CHAT_ID=seu_chat_id_aqui

# ---------------------------------------------------------------------------
# Alertas — Email (SMTP)
# Guia de configuração: USER_GUIDE.md → seção 7.2
# ---------------------------------------------------------------------------
# VEREDAS_SMTP_HOST=smtp.gmail.com
# VEREDAS_SMTP_PORT=587
# VEREDAS_SMTP_USER=seu@email.com
# VEREDAS_SMTP_PASSWORD=sua_senha_de_app
# VEREDAS_ALERT_EMAIL_TO=destinatario@email.com

# ---------------------------------------------------------------------------
# Preferências de alerta
# ---------------------------------------------------------------------------
# VEREDAS_ALERT_MIN_SEVERITY=HIGH      # LOW | MEDIUM | HIGH | CRITICAL
# VEREDAS_ALERT_COOLDOWN_MINUTES=60    # intervalo mínimo entre alertas da mesma IF
